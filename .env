# AWS Environment Configuration
# This file is for AWS deployment - use .env.local for local testing
#
# Note: The following credentials are stored in AWS Secrets Manager and loaded automatically
# by the ECS task definition. They are NOT needed in this file:
# - JWT_SECRET (loaded from taskactivity/jwt/secret)
# - DB_USERNAME, DB_PASSWORD (loaded from taskactivity/database/credentials)

######################
# API Configuration
######################

# API endpoint for AWS deployment (Cloudflare Tunnel)
API_URL=https://taskactivitytracker.com

######################
# Email Configuration
######################

# Enable/disable email notifications
MAIL_ENABLED=true
MAIL_USE_AWS_SDK=true

# Email Application Settings
MAIL_FROM=noreply@taskactivitytracker.com
ADMIN_EMAIL=NMWR5Ab4JuRAZms9Bjmp7LdvQNbhgV003Y8ekvnW811tpqQcd22HEpcAs0nQ/BzE
