{
  "Version": "2012-10-17",
  "Statement": [
      {
          "Sid": "CloudWatchLogsExportPermissions",
          "Effect": "Allow",
          "Action": ["logs:CreateExportTask", "logs:CancelExportTask"],
          "Resource": [
              "arn:aws:logs:us-east-1:378010131175:log-group:/ecs/taskactivity:*"
          ]
      },
      {
          "Sid": "CloudWatchLogsDescribePermissions",
          "Effect": "Allow",
          "Action": [
              "logs:DescribeExportTasks",
              "logs:DescribeLogGroups",
              "logs:DescribeLogStreams"
          ],
          "Resource": "*"
      },
      {
          "Sid": "S3BucketManagementPermissions",
          "Effect": "Allow",
          "Action": [
              "s3:PutBucketPolicy",
              "s3:GetBucketPolicy",
              "s3:ListBucket",
              "s3:GetBucketLocation"
          ],
          "Resource": ["arn:aws:s3:::taskactivity-logs-archive"]
      },
      {
          "Sid": "S3ObjectPermissions",
          "Effect": "Allow",
          "Action": ["s3:GetObject", "s3:ListBucket"],
          "Resource": [
              "arn:aws:s3:::taskactivity-logs-archive",
              "arn:aws:s3:::taskactivity-logs-archive/*"
          ]
      },
      {
          "Sid": "LambdaInvokePermissions",
          "Effect": "Allow",
          "Action": ["lambda:InvokeFunction", "lambda:GetFunction"],
          "Resource": "arn:aws:lambda:us-east-1:378010131175:function:TaskActivityLogExporter"
      }
  ]
}
